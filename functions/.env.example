# Copy to functions/.env (gitignored) for local runs, or set these as GitHub
# Actions secrets for the scheduled cron. The runner reads them from the env.

# Path to a Firebase service-account key JSON (Application Default Credentials).
# Create one: Firebase console → Project settings → Service accounts →
# "Generate new private key". Keep it OUT of git.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Source API keys.
TICKETMASTER_API_KEY=
BANDSINTOWN_APP_ID=

# Affiliate / partner tracking ids (optional until enrolled).
EUROFEST_TM_AFFILIATE=
EUROFEST_EVENTIM_AFFILIATE=
EUROFEST_SKIDDLE_AFFILIATE=
EUROFEST_DICE_AFFILIATE=
